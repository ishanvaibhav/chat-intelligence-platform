<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#0D0D0D">

    <!-- Nova logo text -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NOVA"
        android:textSize="52sp"
        android:textColor="#FFFFFF"
        android:letterSpacing="0.3"
        android:fontFamily="sans-serif-light"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your always-on AI agent"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginBottom="48dp"/>

    <!-- Pulsing status indicator -->
    <View
        android:id="@+id/statusDot"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:background="@drawable/dot_active"
        android:layout_marginBottom="16dp"/>

    <!-- Status text -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap Start to monitor conversation and scenery"
        android:textSize="16sp"
        android:textColor="#CCCCCC"
        android:layout_marginBottom="48dp"/>

    <!-- Start button -->
    <Button
        android:id="@+id/startButton"
        android:layout_width="200dp"
        android:layout_height="52dp"
        android:text="Start Nova"
        android:textColor="#000000"
        android:backgroundTint="#FFFFFF"
        android:layout_marginBottom="16dp"/>

    <!-- Stop button (hidden by default) -->
    <Button
        android:id="@+id/stopButton"
        android:layout_width="200dp"
        android:layout_height="52dp"
        android:text="Stop Nova"
        android:textColor="#FFFFFF"
        android:backgroundTint="#333333"
        android:layout_marginBottom="16dp"
        android:visibility="gone"/>

    <!-- DND permission button -->
    <Button
        android:id="@+id/dndButton"
        android:layout_width="200dp"
        android:layout_height="48dp"
        android:text="Grant DND Access"
        android:textSize="13sp"
        android:textColor="#AAAAAA"
        android:backgroundTint="#1A1A1A"
        android:layout_marginBottom="32dp"/>

    <!-- Info text -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Runs locally on-device.\nAuto-silences during conversation and saves new scenic photos."
        android:textSize="12sp"
        android:textColor="#555555"
        android:gravity="center"
        android:lineSpacingMultiplier="1.5"/>

</LinearLayout>
